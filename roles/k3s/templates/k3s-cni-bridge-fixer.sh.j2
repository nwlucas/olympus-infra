#!/usr/bin/env bash
# k3s-cni-bridge-fixer — workaround for k3s embedded CNI not attaching
# pod veth pairs to the cni0 bridge.
#
# Managed by Ansible — do not edit manually.
#
# k3s creates veth pairs for pods but (in affected versions) skips the
# bridge attachment step. This service detects veths with no master and
# attaches them to cni0, restoring pod-to-service-network routing.

set -euo pipefail

BRIDGE="{{ k3s_cni_bridge | default('cni0') }}"
INTERVAL="{{ k3s_cni_fixer_interval | default(3) }}"

while true; do
    for veth in $(ip link show type veth 2>/dev/null | \
                  awk '/^[0-9]+:/{sub(/@.*$/, "", $2); print $2}'); do
        master=$(ip link show "$veth" 2>/dev/null | awk '/master/{print $NF; exit}')
        if [[ -z "$master" ]]; then
            if ip link set "$veth" master "$BRIDGE" 2>/dev/null; then
                echo "$(date -u '+%Y-%m-%dT%H:%M:%SZ') attached $veth to $BRIDGE"
            fi
        fi
    done
    sleep "$INTERVAL"
done
