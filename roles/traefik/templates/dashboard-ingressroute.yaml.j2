---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: traefik-dashboard-redirect
  namespace: {{ traefik_namespace }}
spec:
  redirectRegex:
    regex: "^(https?://{{ traefik_dashboard_hostname }})/?$"
    replacement: "${1}/dashboard/"
    permanent: false
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: traefik-dashboard
  namespace: {{ traefik_namespace }}
spec:
  entryPoints:
    - web
  routes:
    - match: Host(`{{ traefik_dashboard_hostname }}`) && (PathPrefix(`/dashboard`) || PathPrefix(`/api`))
      kind: Rule
      services:
        - name: api@internal
          kind: TraefikService
    - match: Host(`{{ traefik_dashboard_hostname }}`) && Path(`/`)
      kind: Rule
      middlewares:
        - name: traefik-dashboard-redirect
      services:
        - name: api@internal
          kind: TraefikService
