---
# ArgoCD web UI — HTTP/1.1 backend (server.insecure=true, no h2c support).
# gRPC CLI access uses Tailscale NodePort (argocd login <tailscale-ip>:30080 --plaintext).
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: argocd-server
  namespace: {{ argocd_namespace }}
spec:
  entryPoints:
    - web
  routes:
    - match: Host(`{{ argocd_hostname }}`)
      kind: Rule
      services:
        - name: argocd-server
          port: 80
