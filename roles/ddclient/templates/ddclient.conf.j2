# ddclient configuration — managed by Ansible, do not edit manually
#
# Manages DNS records for this host via Cloudflare:
#   {{ ansible_facts['hostname'] }}.{{ ddclient_subdomain }}.{{ ddclient_zone }}  -> public IP (ipify)
#   {{ ansible_facts['hostname'] }}.{{ ddclient_zone }}                            -> internal IP
{% for fqdn in ddclient_extra_fqdns %}
#   {{ fqdn }}                                                            -> internal IP
{% endfor %}

daemon={{ ddclient_daemon_interval }}
ssl=yes
verbose=no
quiet=no

protocol=cloudflare
zone={{ ddclient_zone }}
ttl={{ ddclient_ttl }}
login=token
password='{{ _ddclient_cf_token }}'

# Public IP record — detected via external web service
use=web, web=https://api.ipify.org/
{{ ansible_facts['hostname'] }}.{{ ddclient_subdomain }}.{{ ddclient_zone }}

# Internal IP records — detected from primary network interface
use=if, if={{ ansible_facts['default_ipv4']['interface'] }}
{{ ansible_facts['hostname'] }}.{{ ddclient_zone }}
{% for fqdn in ddclient_extra_fqdns %}
{{ fqdn }}
{% endfor %}
