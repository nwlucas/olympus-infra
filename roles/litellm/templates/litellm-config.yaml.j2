model_list:
  - model_name: local-fast
    litellm_params:
      model: ollama/glm4-flash
      api_base: http://127.0.0.1:{{ ollama_service_port | default(11434) }}

  - model_name: local-heavy
    litellm_params:
      model: ollama/llama3.3:70b
      api_base: http://127.0.0.1:{{ ollama_service_port | default(11434) }}

  - model_name: sonnet
    litellm_params:
      model: anthropic/claude-sonnet-4-6
      api_key: "{{ litellm_anthropic_api_key }}"

  - model_name: opus
    litellm_params:
      model: anthropic/claude-opus-4-6
      api_key: "{{ litellm_anthropic_api_key }}"

litellm_settings:
  drop_params: true

general_settings:
  master_key: "{{ litellm_master_key | default('') }}"
